    <string name="app_name">OmniAgent</string>
    <string name="accessibility_service_description">OmniAgent Neural Vision acts as a live Guardian Layer to monitor your screen and detect malicious links, phishing attempts, and active threats in real-time across your apps.</string>
    
    <!-- Neural Shield Strings -->
    <string name="neural_shield_title">🛡️ Enable Neural Shield</string>
    <string name="neural_shield_subtitle">Follow these steps to enable protection:</string>
    <string name="neural_shield_open_settings">Open Accessibility Settings</string>
    <string name="neural_shield_dismiss">Dismiss</string>
    <string name="neural_shield_enabled">Neural Shield Active</string>
    <string name="neural_shield_disabled">Neural Shield Inactive</string>
    <string name="neural_shield_guide_step1">1. Tap \'Downloaded Apps\' or \'Your Services\'</string>
    <string name="neural_shield_guide_step2">2. Scroll down and find \'OmniAgent\'</string>
    <string name="neural_shield_guide_step3">3. Tap on \'OmniAgent Neural Shield\'</string>
    <string name="neural_shield_guide_step4">4. Toggle ON the Neural Shield switch</string>
    <string name="neural_shield_guide_step5">5. Confirm by tapping \'OK\' or \'Allow\'</string>
    
